le":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":1,"name":"aa","alive":true,"isAI":false,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":4,"name":"小娟","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":12,"name":"小玲","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":2,"name":"阿华","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":9,"name":"小燕","alive":true,"isAI":true,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null}],"messages":[{"id":1,"type":"phase_start","content":"丘比特连线","visibility":"public","metadata":{},"phase":"cupid","phaseName":"丘比特连线","timestamp":1776612266278},{"id":5,"type":"phase_start","content":"守卫守护","visibility":"public","metadata":{},"phase":"guard","phaseName":"守卫守护","timestamp":1776612291155},{"id":7,"type":"phase_start","content":"狼人讨论","visibility":"public","metadata":{},"phase":"night_werewolf_discuss","phaseName":"狼人讨论","timestamp":1776612305626},{"id":8,"type":"speech","content":"大家注意，2号是我情侣，切勿杀他，否则我需殉情，对狼队极不利。建议首夜刀9号，后置位易藏神职。请保护2号，我们一起往情侣线打。","playerId":8,"playerName":"小红","visibility":"camp","metadata":{},"timestamp":1776612325808},{"id":9,"type":"speech","content":"小红，莫慌。2号是你情侣，动他等于自损一狼，我们绝不会碰。刀9号可行，后置位容易藏神，值得一试。咱们稳扎稳打，先保住实力。","playerId":6,"playerName":"大军","visibility":"camp","metadata":{},"timestamp":1776612337257},{"id":10,"type":"speech","content":"你们读一下胜利规则，人狼恋存在时，狼的胜利规则是什么？情侣的胜利规则是什么？然后你们想想1号会怎么对我们？","playerId":1,"playerName":"aa","visibility":"camp","metadata":{},"timestamp":1776612502188},{"id":11,"type":"speech","content":"哎哟，aa一语惊醒梦中人！1号你想跟2号双宿双飞，咱们可就成炮灰啦，太不够意思了哈哈！9号该刀还刀，不过2号咱们可不敢随便保，说不定还得先送你们一程呢，嘻嘻~","playerId":9,"playerName":"小燕","visibility":"camp","metadata":{},"timestamp":1776612532322},{"id":12,"type":"phase_start","content":"狼人投票","visibility":"public","metadata":{},"phase":"night_werewolf_vote","phaseName":"狼人投票","timestamp":1776612532325},{"id":13,"type":"wolf_vote_result","content":"狼人选择击杀 9号小娟","playerId":8,"visibility":"camp","metadata":{},"voteDetails":[{"voter":"1号小红","target":"9号小娟"},{"voter":"7号大军","target":"2号阿明"},{"voter":"8号aa","target":"2号阿明"},{"voter":"12号小燕","target":"9号小娟"}],"voteCounts":{"4":2,"5":2},"timestamp":1776612557830},{"id":14,"type":"phase_start","content":"女巫技能","visibility":"public","metadata":{},"phase":"witch","phaseName":"女巫技能","timestamp":1776612557833},{"id":16,"type":"phase_start","content":"预言家查验","visibility":"public","metadata":{},"phase":"seer","phaseName":"预言家查验","timestamp":1776612587379},{"id":18,"type":"phase_start","content":"警长竞选","visibility":"public","metadata":{},"phase":"sheriff_campaign","phaseName":"警长竞选","timestamp":1776612596373},{"id":19,"type":"sheriff_candidates","content":"警上：1号小红、3号阿伟、6号小丽、7号大军、10号小玲、11号阿华、12号小燕 | 警下：2号阿明、4号大刚、5号小芳、8号aa、9号小娟","visibility":"public","metadata":{"onStage":[{"id":8,"name":"小红"},{"id":3,"name":"阿伟"},{"id":10,"name":"小丽"},{"id":6,"name":"大军"},{"id":12,"name":"小玲"},{"id":2,"name":"阿华"},{"id":9,"name":"小燕"}],"offStage":[{"id":5,"name":"阿明"},{"id":11,"name":"大刚"},{"id":7,"name":"小芳"},{"id":1,"name":"aa"},{"id":4,"name":"小娟"}]},"timestamp":1776612624330},{"id":20,"type":"phase_start","content":"警长竞选发言","visibility":"public","metadata":{},"phase":"sheriff_speech","phaseName":"警长竞选发言","timestamp":1776612624332},{"id":21,"type":"speech","content":"大家好。我性格温和但逻辑清晰，善于捕捉发言细节与漏洞。警长需要客观梳理信息、精准归票，这正是我的强项。若大家信任我的分析能力，请投我一票，我会理清逻辑，带好节奏，谢谢。","playerId":8,"playerName":"小红","visibility":"public","metadata":{},"timestamp":1776612641306},{"id":22,"type":"speech","content":"1号说自己擅长抓漏洞，但我才是最敏锐的！我逻辑更严密、反应更快，绝不放过任何破绽。选我当警长，我能精准识破伪装，带好人走向胜利！","playerId":3,"playerName":"阿伟","visibility":"public","metadata":{},"timestamp":1776612650928},{"id":23,"type":"speech","content":"我性格谨慎，不轻易表态。但此刻必须站出来：我是预言家，昨夜查验3号阿伟是好人。我会仔细观察大家的发言再判断，绝不盲目归票。请把警徽给我，我会用最稳妥的方式带领好人。","playerId":10,"playerName":"小丽","visibility":"public","metadata":{},"timestamp":1776612667435},{"id":24,"type":"speech","content":"我大军是个沉得住气的人。局势未明，警长最忌心浮气躁。选我，我不盲目跟风，发言不求快但求稳健。我会稳扎稳打，理清脉络，带大家找出真相。","playerId":6,"playerName":"大军","visibility":"public","metadata":{},"timestamp":1776612677450},{"id":25,"type":"speech","content":"我小玲脑子转最快！6号跳预言家查3号，真假先不论，但我绝不会被套路带偏。局势千变万化，死板的人当警长只会被狼人牵着走，得选我这样灵活应变的，见招拆招！","playerId":12,"playerName":"小玲","visibility":"public","metadata":{},"timestamp":1776612682108},{"id":26,"type":"speech","content":"选我当警长，理由有三：1.6号跳预言家，信息繁杂，需理性人梳理；2.我绝不盲目站边，只凭逻辑推导找狼；3.归票必列明理由，绝不冲动。局势越乱越需冷静，请投11号！","playerId":2,"playerName":"阿华","visibility":"public","metadata":{},"timestamp":1776612699653}],"sheriff":null,"couples":null,"playerCount":12,"preset":{"id":"12-guard-cupid","name":"12人守丘局","description":"含守卫丘比特，有情侣第三方","playerCount":12,"roles":["werewolf","werewolf","werewolf","werewolf","seer","witch","guard","hunter","cupid","villager","villager","villager"],"ruleDescriptions":["女巫仅首夜可自救","守卫不可连守","同守同救则死亡","猎人被毒不能开枪","首夜和白天死亡有遗言，后续夜晚死亡无遗言","情侣一方死亡另一方殉情","狼人屠边获胜；好人需清理所有狼人","人狼恋时，好人/狼人都需清理情侣+丘比特才能获胜","人狼恋胜利：情侣+丘比特存活，其他人全死"]},"dayCount":0,"winner":null,"gameOverInfo":null,"speechQueue":[9],"currentSpeakerId":9,"sheriffAssignOrder":null,"self":{"id":1,"name":"aa","role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"alive":true,"isCouple":false,"couplePartner":null,"lastGuardTarget":null,"seerChecks":[]},"pendingAction":null}
