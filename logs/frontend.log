rue,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":1,"name":"aa","alive":false,"isAI":false,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"deathReason":"vote","canVote":true,"canSpeak":false,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":4,"name":"小娟","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":12,"name":"小玲","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":2,"name":"阿华","alive":true,"isAI":true,"role":{"id":"villager","name":"平民","camp":"good","type":"villager","skills":{},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null},{"id":9,"name":"小燕","alive":true,"isAI":true,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"canVote":true,"canSpeak":true,"isSheriff":false,"isCouple":false,"couplePartner":null}],"messages":[{"id":1,"type":"phase_start","content":"丘比特连线","visibility":"public","metadata":{},"phase":"cupid","phaseName":"丘比特连线","timestamp":1776612266278},{"id":5,"type":"phase_start","content":"守卫守护","visibility":"public","metadata":{},"phase":"guard","phaseName":"守卫守护","timestamp":1776612291155},{"id":7,"type":"phase_start","content":"狼人讨论","visibility":"public","metadata":{},"phase":"night_werewolf_discuss","phaseName":"狼人讨论","timestamp":1776612305626},{"id":8,"type":"speech","content":"大家注意，2号是我情侣，切勿杀他，否则我需殉情，对狼队极不利。建议首夜刀9号，后置位易藏神职。请保护2号，我们一起往情侣线打。","playerId":8,"playerName":"小红","visibility":"camp","metadata":{},"timestamp":1776612325808},{"id":9,"type":"speech","content":"小红，莫慌。2号是你情侣，动他等于自损一狼，我们绝不会碰。刀9号可行，后置位容易藏神，值得一试。咱们稳扎稳打，先保住实力。","playerId":6,"playerName":"大军","visibility":"camp","metadata":{},"timestamp":1776612337257},{"id":10,"type":"speech","content":"你们读一下胜利规则，人狼恋存在时，狼的胜利规则是什么？情侣的胜利规则是什么？然后你们想想1号会怎么对我们？","playerId":1,"playerName":"aa","visibility":"camp","metadata":{},"timestamp":1776612502188},{"id":11,"type":"speech","content":"哎哟，aa一语惊醒梦中人！1号你想跟2号双宿双飞，咱们可就成炮灰啦，太不够意思了哈哈！9号该刀还刀，不过2号咱们可不敢随便保，说不定还得先送你们一程呢，嘻嘻~","playerId":9,"playerName":"小燕","visibility":"camp","metadata":{},"timestamp":1776612532322},{"id":12,"type":"phase_start","content":"狼人投票","visibility":"public","metadata":{},"phase":"night_werewolf_vote","phaseName":"狼人投票","timestamp":1776612532325},{"id":13,"type":"wolf_vote_result","content":"狼人选择击杀 9号小娟","playerId":8,"visibility":"camp","metadata":{},"voteDetails":[{"voter":"1号小红","target":"9号小娟"},{"voter":"7号大军","target":"2号阿明"},{"voter":"8号aa","target":"2号阿明"},{"voter":"12号小燕","target":"9号小娟"}],"voteCounts":{"4":2,"5":2},"timestamp":1776612557830},{"id":14,"type":"phase_start","content":"女巫技能","visibility":"public","metadata":{},"phase":"witch","phaseName":"女巫技能","timestamp":1776612557833},{"id":16,"type":"phase_start","content":"预言家查验","visibility":"public","metadata":{},"phase":"seer","phaseName":"预言家查验","timestamp":1776612587379},{"id":18,"type":"phase_start","content":"警长竞选","visibility":"public","metadata":{},"phase":"sheriff_campaign","phaseName":"警长竞选","timestamp":1776612596373},{"id":19,"type":"sheriff_candidates","content":"警上：1号小红、3号阿伟、6号小丽、7号大军、10号小玲、11号阿华、12号小燕 | 警下：2号阿明、4号大刚、5号小芳、8号aa、9号小娟","visibility":"public","metadata":{"onStage":[{"id":8,"name":"小红"},{"id":3,"name":"阿伟"},{"id":10,"name":"小丽"},{"id":6,"name":"大军"},{"id":12,"name":"小玲"},{"id":2,"name":"阿华"},{"id":9,"name":"小燕"}],"offStage":[{"id":5,"name":"阿明"},{"id":11,"name":"大刚"},{"id":7,"name":"小芳"},{"id":1,"name":"aa"},{"id":4,"name":"小娟"}]},"timestamp":1776612624330},{"id":20,"type":"phase_start","content":"警长竞选发言","visibility":"public","metadata":{},"phase":"sheriff_speech","phaseName":"警长竞选发言","timestamp":1776612624332},{"id":21,"type":"speech","content":"大家好。我性格温和但逻辑清晰，善于捕捉发言细节与漏洞。警长需要客观梳理信息、精准归票，这正是我的强项。若大家信任我的分析能力，请投我一票，我会理清逻辑，带好节奏，谢谢。","playerId":8,"playerName":"小红","visibility":"public","metadata":{},"timestamp":1776612641306},{"id":22,"type":"speech","content":"1号说自己擅长抓漏洞，但我才是最敏锐的！我逻辑更严密、反应更快，绝不放过任何破绽。选我当警长，我能精准识破伪装，带好人走向胜利！","playerId":3,"playerName":"阿伟","visibility":"public","metadata":{},"timestamp":1776612650928},{"id":23,"type":"speech","content":"我性格谨慎，不轻易表态。但此刻必须站出来：我是预言家，昨夜查验3号阿伟是好人。我会仔细观察大家的发言再判断，绝不盲目归票。请把警徽给我，我会用最稳妥的方式带领好人。","playerId":10,"playerName":"小丽","visibility":"public","metadata":{},"timestamp":1776612667435},{"id":24,"type":"speech","content":"我大军是个沉得住气的人。局势未明，警长最忌心浮气躁。选我，我不盲目跟风，发言不求快但求稳健。我会稳扎稳打，理清脉络，带大家找出真相。","playerId":6,"playerName":"大军","visibility":"public","metadata":{},"timestamp":1776612677450},{"id":25,"type":"speech","content":"我小玲脑子转最快！6号跳预言家查3号，真假先不论，但我绝不会被套路带偏。局势千变万化，死板的人当警长只会被狼人牵着走，得选我这样灵活应变的，见招拆招！","playerId":12,"playerName":"小玲","visibility":"public","metadata":{},"timestamp":1776612682108},{"id":26,"type":"speech","content":"选我当警长，理由有三：1.6号跳预言家，信息繁杂，需理性人梳理；2.我绝不盲目站边，只凭逻辑推导找狼；3.归票必列明理由，绝不冲动。局势越乱越需冷静，请投11号！","playerId":2,"playerName":"阿华","visibility":"public","metadata":{},"timestamp":1776612699653},{"id":27,"type":"speech","content":"大家别板着脸嘛~选警长当然得选我小燕啦！我活泼嘴甜，能活跃气氛，绝对不让场面冷场！6号跳预言家真假难辨，但我保证带大家开心吃瓜、精准找狼！跟着小燕走，欢乐全都有，快把票投给我呀！","playerId":9,"playerName":"小燕","visibility":"public","metadata":{},"timestamp":1776612710624},{"id":28,"type":"system","content":"10号小玲 退水","visibility":"public","metadata":{},"timestamp":1776612720979},{"id":29,"type":"system","content":"12号小燕 退水","visibility":"public","metadata":{},"timestamp":1776612729344},{"id":30,"type":"phase_start","content":"警长投票","visibility":"public","metadata":{},"phase":"sheriff_vote","phaseName":"警长投票","timestamp":1776612752656},{"id":31,"type":"vote_result","content":"警长投票结果\n2号阿明 → 1号小红\n4号大刚 → 6号小丽\n5号小芳 → 6号小丽\n8号aa → 1号小红\n9号小娟 → 6号小丽","visibility":"public","metadata":{},"voteDetails":[{"voter":"2号阿明","target":"1号小红"},{"voter":"4号大刚","target":"6号小丽"},{"voter":"5号小芳","target":"6号小丽"},{"voter":"8号aa","target":"1号小红"},{"voter":"9号小娟","target":"6号小丽"}],"voteCounts":{"8":2,"10":3},"timestamp":1776612770742},{"id":32,"type":"sheriff_elected","content":"6号小丽 当选警长","visibility":"public","metadata":{},"timestamp":1776612770743},{"id":33,"type":"phase_start","content":"公布死讯","visibility":"public","metadata":{},"phase":"day_announce","phaseName":"公布死讯","timestamp":1776612770745},{"id":34,"type":"system","content":"昨晚是平安夜","visibility":"public","metadata":{},"timestamp":1776612770746},{"id":35,"type":"phase_start","content":"白天讨论","visibility":"public","metadata":{},"phase":"day_discuss","phaseName":"白天讨论","timestamp":1776612770748},{"id":36,"type":"system","content":"警长指定从 2号阿明 开始发言","visibility":"public","metadata":{},"timestamp":1776612784413},{"id":37,"type":"speech","content":"我是女巫，昨晚9号被刀我救了，所以平安夜。6号跳预言家查3号，暂时听着还行。我是直人，信息摊开说，后面谁对跳预言家谁就是狼。过。","playerId":5,"playerName":"阿明","visibility":"public","metadata":{},"timestamp":1776612798256},{"id":38,"type":"speech","content":"6号查我好人，我确实是好人，暂认6号预言家。2号跳女巫救9号，信息先保留，看后续有无对跳。目前信息少，不急着站边，但提醒大家注意听后续发言找漏洞。过。","playerId":3,"playerName":"阿伟","visibility":"public","metadata":{},"timestamp":1776612814741},{"id":39,"type":"speech","content":"我大刚觉得2号女巫报9号银水，6号预言家查3号，这俩先认下！没对跳就先站6号。后面谁再对跳直接标狼！过。","playerId":11,"playerName":"大刚","visibility":"public","metadata":{},"timestamp":1776612833943},{"id":40,"type":"speech","content":"我听着2号和6号语气挺坦然的，感觉没藏着什么情绪，暂时先信女巫和预言家吧。3号是金水，4号附和得也自然，目前看着还算明朗。我就先默默观察，跟着警长走。","playerId":7,"playerName":"小芳","visibility":"public","metadata":{},"timestamp":1776612841147},{"id":41,"type":"speech","content":"2号女巫报银水，6号预言家查3号，均无对跳，暂可认下。局势既明，切忌心浮气躁。咱们稳扎稳打，跟着警长走，排坑找狼便是。过。","playerId":6,"playerName":"大军","visibility":"public","metadata":{},"timestamp":1776612861377},{"id":42,"type":"speech","content":"过","playerId":1,"playerName":"aa","visibility":"public","metadata":{},"timestamp":1776612890793},{"id":43,"type":"speech","content":"2号报我银水，我确实被救了，2号女巫认下。6号预言家暂无对跳，先站边6号。8号划水过，大家注意听后面有无对跳。局势尚明，切忌急躁，稳扎稳打。","playerId":4,"playerName":"小娟","visibility":"public","metadata":{},"timestamp":1776612898101},{"id":44,"type":"speech","content":"2号女巫报9号银水，6号预言家查3号，都没对跳，咱先踏实站边6号警长！局势看着明朗也别掉以轻心，8号这划水过的心思挺深，后面得多听听。我小玲见招拆招，跟着警长稳抓狼！","playerId":12,"playerName":"小玲","visibility":"public","metadata":{},"timestamp":1776612903806},{"id":45,"type":"speech","content":"局势暂明，理由有二：1.2号女巫报9号银水且无对跳，6号预言家同理，均可暂认；2.平安夜佐证女巫真实。但8号划水过态度敷衍，需重点观察。好人稳跟警长，切忌急躁排坑。","playerId":2,"playerName":"阿华","visibility":"public","metadata":{},"timestamp":1776612917440},{"id":46,"type":"speech","content":"哎呀，2号是女巫，难怪1号昨晚死保2号，原来是情侣心有灵犀！6号和2号没对跳，我先站边啦~8号光速划水，是不是想保存体力晚上出来浪呀？大家盯紧他哦，跟着警长走，吃瓜找狼两不误~","playerId":9,"playerName":"小燕","visibility":"public","metadata":{},"timestamp":1776612940425},{"id":47,"type":"speech","content":"12号说得对，2号确是我情侣，他跳女巫我自然力保。6号预言家暂认。8号划水态度敷衍，需重点观察。既然2号是女巫，我会全力护他，大家跟警长稳扎稳打排坑即可。","playerId":8,"playerName":"小红","visibility":"public","metadata":{},"timestamp":1776612954305},{"id":48,"type":"speech","content":"3号金水，2号女巫，1号2号情侣，信息均暂认。8号划水过需警惕，警徽流先验8。情侣牌注意分寸，别成狼人突破口。大家跟警徽走，稳扎稳打。","playerId":10,"playerName":"小丽","visibility":"public","metadata":{},"timestamp":1776612971348},{"id":49,"type":"phase_start","content":"白天投票","visibility":"public","metadata":{},"phase":"day_vote","phaseName":"白天投票","timestamp":1776612971349},{"id":50,"type":"phase_start","content":"放逐后处理","visibility":"public","metadata":{},"phase":"post_vote","phaseName":"放逐后处理","timestamp":1776613062378},{"id":51,"type":"vote_result","content":"投票结果\n1号小红 → 8号aa\n2号阿明 → 8号aa\n3号阿伟 → 8号aa\n4号大刚 → 8号aa\n5号小芳 → 8号aa\n6号小丽 → 弃权\n7号大军 → 6号小丽\n8号aa → 1号小红\n9号小娟 → 8号aa\n10号小玲 → 8号aa\n11号阿华 → 弃权\n12号小燕 → 弃权","visibility":"public","metadata":{},"voteDetails":[{"voter":"1号小红","target":"8号aa"},{"voter":"2号阿明","target":"8号aa"},{"voter":"3号阿伟","target":"8号aa"},{"voter":"4号大刚","target":"8号aa"},{"voter":"5号小芳","target":"8号aa"},{"voter":"6号小丽","target":"弃权"},{"voter":"7号大军","target":"6号小丽"},{"voter":"8号aa","target":"1号小红"},{"voter":"9号小娟","target":"8号aa"},{"voter":"10号小玲","target":"8号aa"},{"voter":"11号阿华","target":"弃权"},{"voter":"12号小燕","target":"弃权"}],"voteCounts":{"1":7,"8":1,"10":1},"timestamp":1776613062379},{"id":52,"type":"death_announce","content":"8号aa 死亡","visibility":"public","metadata":{},"deaths":[{"id":1,"name":"aa","alive":false,"isAI":false,"role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"debugRole":null,"deathReason":"vote"}],"timestamp":1776613062381},{"id":53,"type":"last_words","content":"1","playerId":1,"playerName":"aa","visibility":"public","metadata":{},"timestamp":1776613096772},{"id":54,"type":"phase_start","content":"守卫守护","visibility":"public","metadata":{},"phase":"guard","phaseName":"守卫守护","timestamp":1776613096783},{"id":56,"type":"phase_start","content":"狼人讨论","visibility":"public","metadata":{},"phase":"night_werewolf_discuss","phaseName":"狼人讨论","timestamp":1776613122908},{"id":57,"type":"speech","content":"8出局6必报查杀，形势危急。大家冷静想想，刀2我必殉情，狼队连损两人太亏。刀6夺警徽才能切断好人视野，这才是破局关键。今晚刀6，别内耗了。","playerId":8,"playerName":"小红","visibility":"camp","metadata":{},"timestamp":1776613142933},{"id":58,"type":"speech","content":"8号走了，别慌。1号说得对，动2必双死，我们人少亏不起。唯有落刀6号，断好人视野夺警徽才是破局关键。12号稳住，今晚就刀6，不要内耗。","playerId":6,"playerName":"大军","visibility":"camp","metadata":{},"timestamp":1776613172506}],"sheriff":10,"couples":null,"playerCount":12,"preset":{"id":"12-guard-cupid","name":"12人守丘局","description":"含守卫丘比特，有情侣第三方","playerCount":12,"roles":["werewolf","werewolf","werewolf","werewolf","seer","witch","guard","hunter","cupid","villager","villager","villager"],"ruleDescriptions":["女巫仅首夜可自救","守卫不可连守","同守同救则死亡","猎人被毒不能开枪","首夜和白天死亡有遗言，后续夜晚死亡无遗言","情侣一方死亡另一方殉情","狼人屠边获胜；好人需清理所有狼人","人狼恋时，好人/狼人都需清理情侣+丘比特才能获胜","人狼恋胜利：情侣+丘比特存活，其他人全死"]},"dayCount":2,"winner":null,"gameOverInfo":null,"speechQueue":[9],"currentSpeakerId":9,"sheriffAssignOrder":5,"self":{"id":1,"name":"aa","role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"alive":false,"isCouple":false,"couplePartner":null,"lastGuardTarget":null,"seerChecks":[]},"pendingAction":null}
