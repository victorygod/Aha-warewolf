。5号预言家身份大概率可信，6号金水可认。毒药未用，后续女巫视角缺失，请守卫暗保神职。好人跟5号警长走，仔细分辨警徽流7、11的验人结果！","playerId":12,"playerName":"阿伟","visibility":"public","metadata":{},"timestamp":1776791093179},{"id":31,"type":"death_announce","content":"2号阿伟 死亡","visibility":"public","metadata":{},"deaths":[{"id":12,"name":"阿伟","reason":"wolf"}],"timestamp":1776791093180},{"id":32,"type":"phase_start","content":"白天讨论","visibility":"public","metadata":{},"phase":"day_discuss","phaseName":"白天讨论","timestamp":1776791093183},{"id":33,"type":"system","content":"警长指定从 3号小云 开始发言","visibility":"public","metadata":{},"timestamp":1776791120112},{"id":34,"type":"speech","content":"3号好人。2号女巫遗言认5号预言家，无人对跳，5号大概率真预，6号金水认下。警徽流7、11，听他俩发言。女巫已走，守卫注意保护神职。我跟5号警长走。","playerId":6,"playerName":"小云","visibility":"public","metadata":{},"timestamp":1776791132384},{"id":35,"type":"speech","content":"4号好人。2号女巫认下5号，5号单预言家，6号金水无疑。警徽流7、11，重点听他俩发言。我跟警长5号走，过。","playerId":3,"playerName":"阿鹏","visibility":"public","metadata":{},"timestamp":1776791139372},{"id":36,"type":"speech","content":"6号金水。5号单预言家，2号女巫认下，5号真预无疑。感谢5号验我，我认下这个身份。警徽流7、11，听他俩发言分辨。女巫已走，好人抱紧5号警长，我跟5号走。","playerId":10,"playerName":"小芳","visibility":"public","metadata":{},"timestamp":1776791152144},{"id":37,"type":"speech","content":"7号村民。5号单预2号女巫认，6号金水无疑，我警上退水已表水，验我必金水。重点点1号，警上平民抢警徽毫无逻辑，大概率狼。认5号，过。","playerId":9,"playerName":"小娟","visibility":"public","metadata":{},"timestamp":1776791166022},{"id":38,"type":"speech","content":"8号好人。2号女巫认下5号，5号真预无疑，6号金水。1号警上村民抢警徽毫无逻辑，像狼抢警徽，重点关注。7号退水表水还行。守卫今晚必保5号警长，好人紧跟5号走，过。","playerId":5,"playerName":"阿明","visibility":"public","metadata":{},"timestamp":1776791187939}],"sheriff":8,"couples":null,"playerCount":12,"preset":{"id":"12-guard-cupid","name":"12人守丘局","description":"含守卫丘比特，有情侣第三方","playerCount":12,"roles":["werewolf","werewolf","werewolf","werewolf","seer","witch","guard","hunter","cupid","villager","villager","villager"],"ruleDescriptions":["女巫仅首夜可自救","守卫不可连守","同守同救则死亡","猎人被毒不能开枪","首夜和白天死亡有遗言，后续夜晚死亡无遗言","情侣一方死亡另一方殉情","狼人屠边获胜；好人需清理所有狼人","人狼恋时，好人/狼人都需清理情侣+丘比特才能获胜","人狼恋胜利：情侣+丘比特存活，其他人全死"]},"dayCount":1,"winner":null,"gameOverInfo":null,"speechQueue":[1,11,4,2,7,8],"currentSpeakerId":1,"sheriffAssignOrder":6,"self":{"id":1,"name":"aa","role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"alive":true,"isCouple":false,"couplePartner":null,"lastGuardTarget":null,"seerChecks":[]},"pendingAction":{"requestId":"1-speak-1776791187941-qya9bjccaji","action":"speak"}}
