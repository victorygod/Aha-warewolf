"阿伟"},{"id":6,"name":"小云"},{"id":3,"name":"阿鹏"},{"id":10,"name":"小芳"},{"id":5,"name":"阿明"},{"id":1,"name":"aa"},{"id":11,"name":"阿杰"},{"id":2,"name":"Claude"}]},"timestamp":1776790968357},{"id":19,"type":"phase_start","content":"警长竞选发言","visibility":"public","metadata":{},"phase":"sheriff_speech","phaseName":"警长竞选发言","timestamp":1776790968360},{"id":20,"type":"speech","content":"我是1号阿华，上警是为了拿警长带队。作为村民，我没有信息包袱，能客观分析发言和票型。我会用理性推理找狼，警徽也不会乱飞。选我，好人方向更清晰。","playerId":7,"playerName":"阿华","visibility":"public","metadata":{},"timestamp":1776790976323},{"id":21,"type":"speech","content":"我是真预言家！昨夜验6号小芳，金水。1号平民拿警徽毫无意义，信息权必须在真预言家手里。警徽流先7后11。6号及警下好人们，请把票投给我，我带队抓狼！","playerId":8,"playerName":"大军","visibility":"public","metadata":{},"timestamp":1776791006549},{"id":22,"type":"speech","content":"5号给我警徽流，我是好人验我必金水。1号村民抢警徽毫无意义！我上警本为诈身份，既然5号起跳，我7号村民退水，把舞台留给预言家。警下听11号和后置位发言。","playerId":9,"playerName":"小娟","visibility":"public","metadata":{},"timestamp":1776791028210}],"sheriff":null,"couples":null,"playerCount":12,"preset":{"id":"12-guard-cupid","name":"12人守丘局","description":"含守卫丘比特，有情侣第三方","playerCount":12,"roles":["werewolf","werewolf","werewolf","werewolf","seer","witch","guard","hunter","cupid","villager","villager","villager"],"ruleDescriptions":["女巫仅首夜可自救","守卫不可连守","同守同救则死亡","猎人被毒不能开枪","首夜和白天死亡有遗言，后续夜晚死亡无遗言","情侣一方死亡另一方殉情","狼人屠边获胜；好人需清理所有狼人","人狼恋时，好人/狼人都需清理情侣+丘比特才能获胜","人狼恋胜利：情侣+丘比特存活，其他人全死"]},"dayCount":0,"winner":null,"gameOverInfo":null,"speechQueue":[4],"currentSpeakerId":4,"sheriffAssignOrder":null,"self":{"id":1,"name":"aa","role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"alive":true,"isCouple":false,"couplePartner":null,"lastGuardTarget":null,"seerChecks":[]},"pendingAction":null}
