,{"id":3,"name":"阿伟"},{"id":10,"name":"小丽"},{"id":6,"name":"大军"},{"id":12,"name":"小玲"},{"id":2,"name":"阿华"},{"id":9,"name":"小燕"}],"offStage":[{"id":5,"name":"阿明"},{"id":11,"name":"大刚"},{"id":7,"name":"小芳"},{"id":1,"name":"aa"},{"id":4,"name":"小娟"}]},"timestamp":1776612624330},{"id":20,"type":"phase_start","content":"警长竞选发言","visibility":"public","metadata":{},"phase":"sheriff_speech","phaseName":"警长竞选发言","timestamp":1776612624332},{"id":21,"type":"speech","content":"大家好。我性格温和但逻辑清晰，善于捕捉发言细节与漏洞。警长需要客观梳理信息、精准归票，这正是我的强项。若大家信任我的分析能力，请投我一票，我会理清逻辑，带好节奏，谢谢。","playerId":8,"playerName":"小红","visibility":"public","metadata":{},"timestamp":1776612641306},{"id":22,"type":"speech","content":"1号说自己擅长抓漏洞，但我才是最敏锐的！我逻辑更严密、反应更快，绝不放过任何破绽。选我当警长，我能精准识破伪装，带好人走向胜利！","playerId":3,"playerName":"阿伟","visibility":"public","metadata":{},"timestamp":1776612650928},{"id":23,"type":"speech","content":"我性格谨慎，不轻易表态。但此刻必须站出来：我是预言家，昨夜查验3号阿伟是好人。我会仔细观察大家的发言再判断，绝不盲目归票。请把警徽给我，我会用最稳妥的方式带领好人。","playerId":10,"playerName":"小丽","visibility":"public","metadata":{},"timestamp":1776612667435},{"id":24,"type":"speech","content":"我大军是个沉得住气的人。局势未明，警长最忌心浮气躁。选我，我不盲目跟风，发言不求快但求稳健。我会稳扎稳打，理清脉络，带大家找出真相。","playerId":6,"playerName":"大军","visibility":"public","metadata":{},"timestamp":1776612677450},{"id":25,"type":"speech","content":"我小玲脑子转最快！6号跳预言家查3号，真假先不论，但我绝不会被套路带偏。局势千变万化，死板的人当警长只会被狼人牵着走，得选我这样灵活应变的，见招拆招！","playerId":12,"playerName":"小玲","visibility":"public","metadata":{},"timestamp":1776612682108},{"id":26,"type":"speech","content":"选我当警长，理由有三：1.6号跳预言家，信息繁杂，需理性人梳理；2.我绝不盲目站边，只凭逻辑推导找狼；3.归票必列明理由，绝不冲动。局势越乱越需冷静，请投11号！","playerId":2,"playerName":"阿华","visibility":"public","metadata":{},"timestamp":1776612699653},{"id":27,"type":"speech","content":"大家别板着脸嘛~选警长当然得选我小燕啦！我活泼嘴甜，能活跃气氛，绝对不让场面冷场！6号跳预言家真假难辨，但我保证带大家开心吃瓜、精准找狼！跟着小燕走，欢乐全都有，快把票投给我呀！","playerId":9,"playerName":"小燕","visibility":"public","metadata":{},"timestamp":1776612710624},{"id":28,"type":"system","content":"10号小玲 退水","visibility":"public","metadata":{},"timestamp":1776612720979},{"id":29,"type":"system","content":"12号小燕 退水","visibility":"public","metadata":{},"timestamp":1776612729344},{"id":30,"type":"phase_start","content":"警长投票","visibility":"public","metadata":{},"phase":"sheriff_vote","phaseName":"警长投票","timestamp":1776612752656}],"sheriff":null,"couples":null,"playerCount":12,"preset":{"id":"12-guard-cupid","name":"12人守丘局","description":"含守卫丘比特，有情侣第三方","playerCount":12,"roles":["werewolf","werewolf","werewolf","werewolf","seer","witch","guard","hunter","cupid","villager","villager","villager"],"ruleDescriptions":["女巫仅首夜可自救","守卫不可连守","同守同救则死亡","猎人被毒不能开枪","首夜和白天死亡有遗言，后续夜晚死亡无遗言","情侣一方死亡另一方殉情","狼人屠边获胜；好人需清理所有狼人","人狼恋时，好人/狼人都需清理情侣+丘比特才能获胜","人狼恋胜利：情侣+丘比特存活，其他人全死"]},"dayCount":0,"winner":null,"gameOverInfo":null,"speechQueue":[],"currentSpeakerId":null,"sheriffAssignOrder":null,"self":{"id":1,"name":"aa","role":{"id":"werewolf","name":"狼人","camp":"wolf","type":"wolf","skills":{"explode":{"type":"instant","availablePhases":["sheriff_campaign","sheriff_speech","sheriff_vote","day_discuss","day_vote"]}},"state":{}},"state":{},"alive":true,"isCouple":false,"couplePartner":null,"lastGuardTarget":null,"seerChecks":[]},"pendingAction":{"requestId":"1-sheriff_vote-1776612752665-eg9lm87sksa","action":"sheriff_vote","allowedTargets":[8,3,10,6,2]}}
